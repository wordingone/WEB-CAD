  "keywords": ["cad", "ifc", "bim", "nurbs", "3d", "architecture", "geometry", "parametric"],
  "engines": {
    "node": ">=18"
  },
  "mcp": {
    "server": "tools/mcp/webcad-mcp.mjs",
    "transport": "stdio",
    "runtime": "node",
    "documentation": "docs/webcad-agent.md",
    "samplePrompts": "docs/sample-prompts.md"
