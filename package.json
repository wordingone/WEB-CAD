{
  "name": "gemma-cad",
  "version": "0.1.0",
  "description": "Browser-native 3D architectural design tool — Gemma 4 fine-tuned on parametric IFC.",
  "license": "CC-BY-4.0",
  "type": "module",
  "private": true,
  "scripts": {
    "spike-b": "bun scripts/spike-b-ifc-mining.ts",
    "extract-walls": "bun scripts/extract-walls.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "web:dev": "vite --config web/vite.config.ts --port 5175 --strictPort",
    "web:build": "vite build --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts",
    "web:typecheck": "tsc --noEmit -p web/tsconfig.json",
    "audit:stubs": "bun scripts/audit-stubs.ts",
    "audit:parity": "bun scripts/audit-zip-parity.ts",
    "audit:dispatch": "bun scripts/audit-dispatch-routing.ts",
    "audit:vite-spawn": "node scripts/audit-vite-spawn.mjs",
    "audit:brace": "node scripts/audit-brace-balance.mjs",
    "audit:undo": "bun scripts/audit-undo-coverage.ts",
    "verify": "bun run typecheck && bun run web:typecheck && bun run audit:stubs && bun run audit:parity && bun run audit:dispatch && bun run audit:vite-spawn && bun run audit:brace && bun run audit:undo && bun test web/",
    "verify:deploy": "bun scripts/validate-deploy.ts",
    "shared-browser:start": "powershell -File scripts/shared-browser/start.ps1",
    "shared-browser:stop": "powershell -File scripts/shared-browser/stop.ps1",
    "shared-browser:sweep": "node scripts/shared-browser-sweep.mjs",
    "shared-browser:watch": "node scripts/shared-browser-watch.mjs",
    "master-autofwd": "node scripts/gemma-master-autofwd.mjs",
    "master-autofwd:dry": "node scripts/gemma-master-autofwd.mjs --dry-run",
    "master-autofwd:install": "powershell -File scripts/gemma-master-autofwd-task.ps1 install",
    "master-autofwd:uninstall": "powershell -File scripts/gemma-master-autofwd-task.ps1 uninstall",
    "master-autofwd:status": "powershell -File scripts/gemma-master-autofwd-task.ps1 status",
    "master-autofwd:restart": "powershell -File scripts/gemma-master-autofwd-task.ps1 restart",
    "verify:raw": "node -e \"process.stderr.write('SUSPENDED until 2026-05-19 — do not run or cite in PR smoke packs.\\n'); process.exit(0);\"",
    "demo:record": "node scripts/demo-record.mjs",
    "demo:drive": "node scripts/demo-drive.mjs",
    "verify:cdp": "node -e \"process.stderr.write('DEPRECATED: verify:cdp removed — use: bun run verify:raw\\n'); process.exit(2);\"",
    "cdp": "node --experimental-strip-types scripts/cdp.ts",
    "kg:build": "bun scripts/kg-build.ts",
    "kg:stats": "bun scripts/kg-build.ts --stats",
    "capability-bench": "bun scripts/capability-bench.ts",
    "snapshot": "bun scripts/capability-bench.ts",
    "judge": "bun web/test/capability/judge.ts",
    "baseline:bare-gemma": "bun web/test/capability/baselines/bare-gemma.ts",
    "baseline:blender-mcp": "bun web/test/capability/baselines/blender-mcp.ts",
    "baseline:compare": "bun web/test/capability/baselines/post-comparison.ts",
    "llama:proxy": "bun scripts/llama-proxy.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "jspdf": "^4.2.1",
    "replicad": "^0.20.0",
    "replicad-opencascadejs": "^0.20.0",
    "rhino3dm": "^8.17.0",
    "three": "^0.162.0",
    "three-bvh-csg": "^0.0.18",
    "verb-nurbs": "^3.0.3",
    "web-ifc": "^0.0.77"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/node": "^20.11.0",
    "@types/three": "^0.162.0",
    "bun-types": "^1.3.13",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "rollup": "^4.60.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.10",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
