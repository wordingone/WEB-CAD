{
  "version": 1,
  "purpose": "Vendor-trademarked compound tokens that MUST NOT appear in spatial-dictionary.yaml synonyms[]. See spatial-dictionary.LICENSE.md for the full copyright + trademark analysis.",
  "brands": [
    "rhino",
    "rhinoceros",
    "autocad",
    "revit",
    "sketchup",
    "blender",
    "solidworks",
    "fusion360",
    "fusion 360",
    "inventor",
    "catia",
    "creo",
    "nx",
    "siemens nx",
    "openscad",
    "freecad",
    "archicad",
    "vectorworks",
    "tinkercad",
    "onshape",
    "modo",
    "maya",
    "3dsmax",
    "3ds max",
    "cinema4d",
    "houdini",
    "zbrush",
    "moi3d",
    "moi 3d"
  ],
  "compoundTokens": [
    "_BlockEdit",
    "_PEDIT",
    "_BMODIFY",
    "RhinoCommand",
    "RhinoLink",
    "RhinoScript",
    "RevitFamily",
    "RevitLink",
    "RevitParameter",
    "MotionPath",
    "FamilyEditor",
    "AutoCADCommand",
    "BlenderModifier",
    "SketchUpFollow",
    "SolidworksFeature",
    "FusionTimeline",
    "InventorPart",
    "CatiaPart",
    "PartDesign",
    "VectorworksLayer",
    "ArchiCADStory",
    "MoiPolyline",
    "ZBrushDynamesh"
  ],
  "regex": [
    "(?i)\\bRhino[A-Z][a-z]+",
    "(?i)\\bAutoCAD[A-Z][a-z]+",
    "(?i)\\bSketchUp[A-Z][a-z]+",
    "(?i)\\bRevit[A-Z][a-z]+",
    "(?i)\\bBlender[A-Z][a-z]+",
    "(?i)\\bFusion ?360",
    "(?i)\\b3ds ?Max",
    "(?i)\\bCinema ?4D"
  ],
  "notes": "Brands and compoundTokens are exact-match (case-insensitive) substring rejects. regex[] are RE2-compatible patterns scanned over each synonyms[] entry. The audit-aliases.ts script applies all three on every alias row and exits non-zero on any match."
}
