      "max": 29.4
    },
    {
      "id": "footprint_depth",
      "description": "Footprint Y-span 18 ± 5%",
      "type": "dimension",
      "axis": "Y",
      "min": 17.1,
      "max": 18.9
    },
    {
      "id": "floor_count",
      "description": "4 building storeys",
      "type": "count",
      "target": "IfcBuildingStorey",
      "min": 4,
      "max": 4
